# Local Postgres (matches docker-compose.yml)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/urlshortener"

# Redis — Layer 2. For local Docker (docker-compose.full.yml), use the REST proxy:
UPSTASH_REDIS_REST_URL="http://localhost:8079"
UPSTASH_REDIS_REST_TOKEN="local_dev_token"
# For production, replace with your real Upstash project values.

# Kafka — Layer 5
KAFKA_BROKER="localhost:9092"

# ClickHouse — Layer 5
CLICKHOUSE_URL="http://localhost:8123"
