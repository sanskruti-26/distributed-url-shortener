generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Url {
  id         Int      @id @default(autoincrement())
  shortCode  String   @unique
  longUrl    String
  clickCount Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([longUrl])
}
